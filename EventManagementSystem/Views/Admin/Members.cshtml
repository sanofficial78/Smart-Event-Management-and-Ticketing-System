@model IEnumerable<EventManagementSystem.Models.Member>
@{
    ViewData["Title"] = "Members";
    Layout = "_AdminLayout";
}
<div class="table-admin">
    <div class="card-header">
        <i class="bi bi-people me-2"></i>Registered Members
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Joined</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model)
                {
                    <tr>
                        <td>@m.MemberID</td>
                        <td><strong>@m.FirstName @m.LastName</strong></td>
                        <td>@m.Email</td>
                        <td>@(m.Phone ?? "—")</td>
                        <td>@m.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>@if (m.IsActive) { <span class="admin-badge bg-success">Active</span> } else { <span class="admin-badge bg-secondary">Inactive</span> }</td>
                        <td>
                            <a asp-action="MemberDetails" asp-route-id="@m.MemberID" class="btn btn-sm btn-outline-primary">Details</a>
                            <form asp-action="ToggleMemberStatus" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@m.MemberID" />
                                <button type="submit" class="btn btn-sm btn-outline-@(m.IsActive ? "warning" : "success")">@(m.IsActive ? "Deactivate" : "Activate")</button>
                            </form>
                            <form asp-action="DeleteMember" method="post" class="d-inline" onsubmit="return confirm('Delete this member? Cannot undo.');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@m.MemberID" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
