@model Event
@{
    ViewData["Title"] = Model.Title;
    var isMember = ViewBag.IsMember == true;
    var reviews = ViewBag.Reviews as IEnumerable<Review> ?? Enumerable.Empty<Review>();
    var hasReviewed = ViewBag.HasReviewed == true;
    var hasBooking = ViewBag.HasBooking == true;
    var eventPassed = Model.EventDate < DateTime.UtcNow;
    var canReview = isMember && !hasReviewed && (eventPassed || hasBooking);
}
<h2>@Model.Title</h2>
<div class="row">
    <div class="col-md-8">
        <p><strong>Category:</strong> @Model.Category</p>
        <p><strong>Date:</strong> @Model.EventDate.ToString("MMMM dd, yyyy 'at' HH:mm")</p>
        <p><strong>Venue:</strong> @Model.Venue?.Name, @Model.Venue?.Address, @Model.Venue?.City</p>
        @if (isMember && Model.EventSeats.Any())
        {
            <h4>Seat Options</h4>
            <table class="table table-sm">
                <tr><th>Type</th><th>Price</th><th>Available</th></tr>
                @foreach (var s in Model.EventSeats)
                {
                    <tr>
                        <td>@s.SeatType</td>
                        <td>Rs. @CurrencyHelper.ToLkr(s.Price).ToString("N2")</td>
                        <td>@s.AvailableSeats</td>
                    </tr>
                }
            </table>
        }
        else if (!isMember && Model.EventSeats.Any())
        {
            var avail = Model.EventSeats.Any(s => s.AvailableSeats > 0) ? "Available" : "Full";
            <p><strong>Availability:</strong> <span class="badge @(avail == "Available" ? "bg-success" : "bg-secondary")">@avail</span></p>
        }
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="mt-3">
                <h4>Description</h4>
                <p>@Model.Description</p>
            </div>
        }
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <p class="card-text">From Rs. @CurrencyHelper.ToLkr(Model.BasePrice).ToString("N2")</p>
                @if (isMember)
                {
                    var canBook = Model.EventSeats.Any(s => s.AvailableSeats > 0);
                    if (canBook)
                    {
                        <a asp-controller="Bookings" asp-action="Book" asp-route-id="@Model.EventID" class="btn btn-primary w-100">Book Tickets</a>
                    }
                    else
                    {
                        <button class="btn btn-secondary w-100" disabled>Sold Out</button>
                    }
                    @if (canReview)
                    {
                        <a asp-controller="Reviews" asp-action="Create" asp-route-eventId="@Model.EventID" class="btn btn-outline-primary w-100 mt-2">
                            ★ Submit a Review
                        </a>
                    }
                    else if (!hasReviewed && isMember && !eventPassed && !hasBooking)
                    {
                        <p class="small text-muted mt-2 mb-0">Book tickets to submit a review, or wait until after the event.</p>
                    }
                }
                else
                {
                    <p class="small text-muted">Sign in to book tickets</p>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary">Register</a>
                }
            </div>
        </div>
    </div>
</div>

<div class="mt-4 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h4 class="mb-0">Reviews</h4>
    @if (canReview)
    {
        <a asp-controller="Reviews" asp-action="Create" asp-route-eventId="@Model.EventID" class="btn btn-sm btn-outline-primary">Write a review</a>
    }
</div>
@if (reviews.Any())
{
    @foreach (var r in reviews)
    {
        <div class="card mb-2">
            <div class="card-body py-2">
                <strong>@r.Member?.FirstName @r.Member?.LastName</strong>
                <span class="text-warning">@(new string('★', r.Rating))@(new string('☆', 5 - r.Rating))</span>
                <span class="text-muted small">@r.ReviewDate.ToString("MMM dd, yyyy")</span>
                @if (!string.IsNullOrEmpty(r.Comment))
                {
                    <p class="mb-0 mt-1">@r.Comment</p>
                }
            </div>
        </div>
    }
}
else
{
    <p class="text-muted">No reviews yet.</p>
}
