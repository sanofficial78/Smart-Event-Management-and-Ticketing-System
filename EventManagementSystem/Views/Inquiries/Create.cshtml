@model InquiryViewModel
@{
    ViewData["Title"] = "Contact / Send Inquiry";
}
<h2>Send Inquiry</h2>
<p>Guests can send general questions about events or membership. We will respond shortly.</p>
<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div class="form-group mb-2">
        <label asp-for="GuestName">Your Name</label>
        <input asp-for="GuestName" class="form-control" required />
    </div>
    <div class="form-group mb-2">
        <label asp-for="GuestEmail">Email</label>
        <input asp-for="GuestEmail" class="form-control" type="email" required />
    </div>
    <div class="form-group mb-2">
        <label asp-for="Subject">Subject</label>
        <input asp-for="Subject" class="form-control" placeholder="e.g. Membership, Event availability" required />
    </div>
    <div class="form-group mb-2">
        <label asp-for="Message">Message</label>
        <textarea asp-for="Message" class="form-control" rows="5" required></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Send Inquiry</button>
</form>
