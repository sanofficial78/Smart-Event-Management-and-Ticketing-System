<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Metropolitan Cultural Council</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-primary">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">Metro Cultural Council</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Events" asp-action="Index">Events</a></li>
                        @if (ViewBag.IsMember == true)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Bookings" asp-action="MyBookings">My Bookings</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Reviews" asp-action="MyReviews">My Reviews</a></li>
                        }
                        <li class="nav-item"><a class="nav-link" asp-controller="Reviews" asp-action="Index">Browse Reviews</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About Us</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Inquiries" asp-action="Create">Contact</a></li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (ViewBag.IsAdmin == true)
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-shield-lock"></i> Admin</a></li>
                        }
                        @if (ViewBag.IsMember == true)
                        {
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link">Sign Out</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Sign In</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register">Register</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main class="container py-4">
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                @TempData["Message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>
    <footer class="site-footer">
        <div class="footer-sponsors">
            <div class="container">
                <h6 class="sponsors-title">Our Sponsors</h6>
                <div class="sponsors-grid">
                    <div class="sponsor-item">Metro Arts Foundation</div>
                    <div class="sponsor-item">City Cultural Trust</div>
                    <div class="sponsor-item">Community First Bank</div>
                    <div class="sponsor-item">Local Heritage Society</div>
                </div>
            </div>
        </div>
        <div class="footer-main">
            <div class="container">
                <div class="row g-4 py-4">
                    <div class="col-md-3 col-6">
                        <h6 class="footer-heading">Company</h6>
                        <ul class="footer-links">
                            <li><a asp-controller="Home" asp-action="About">About Us</a></li>
                            <li><a asp-controller="Home" asp-action="Privacy">Privacy Policy</a></li>
                            <li><a asp-controller="Admin" asp-action="Login">Staff Login</a></li>
                            <li><a href="#">Careers</a></li>
                            <li><a href="#">Partners</a></li>
                        </ul>
                    </div>
                    <div class="col-md-3 col-6">
                        <h6 class="footer-heading">Explore</h6>
                        <ul class="footer-links">
                            <li><a asp-controller="Events" asp-action="Index">All Events</a></li>
                            <li><a asp-controller="Reviews" asp-action="Index">Browse Reviews</a></li>
                            <li><a asp-controller="Events" asp-action="Index" asp-route-category="Music">Music</a></li>
                            <li><a asp-controller="Events" asp-action="Index" asp-route-category="Theatre">Theatre</a></li>
                            <li><a asp-controller="Events" asp-action="Index" asp-route-category="Exhibition">Exhibitions</a></li>
                        </ul>
                    </div>
                    <div class="col-md-3 col-6">
                        <h6 class="footer-heading">Support</h6>
                        <ul class="footer-links">
                            <li><a asp-controller="Inquiries" asp-action="Create">Contact Us</a></li>
                            <li><a asp-controller="Home" asp-action="Feedback">Feedback</a></li>
                            <li><a asp-controller="Account" asp-action="Register">Become a Member</a></li>
                        </ul>
                    </div>
                    <div class="col-md-3 col-6">
                        <h6 class="footer-heading">Website Developer</h6>
                        <div class="footer-contact">
                            <a href="mailto:Salmanmax543@gmail.com" class="footer-contact-link">
                                <span class="footer-contact-icon">✉</span> Salmanmax543@gmail.com
                            </a>
                            <a href="tel:+94781863115" class="footer-contact-link">
                                <span class="footer-contact-icon">📞</span> +94 78 186 3115
                            </a>
                            <div class="footer-contact-link">
                                <span class="footer-contact-icon">📍</span> Sri Lanka, Kurunegala
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-6 text-center text-md-start">
                        &copy; 2025 Metropolitan Cultural Council — Smart Event Management
                    </div>
                    <div class="col-md-6 text-center text-md-end mt-2 mt-md-0">
                        <span class="footer-credits">Developed with care in Sri Lanka</span>
                    </div>
                </div>
            </div>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
