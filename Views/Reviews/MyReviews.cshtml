@model IEnumerable<Review>
@{
    ViewData["Title"] = "My Reviews";
}
<h2>My Reviews</h2>
<p class="text-muted">Reviews you have submitted for events.</p>
@if (Model.Any())
{
    <div class="list-group">
        @foreach (var r in Model)
        {
            <div class="list-group-item">
                <div class="d-flex w-100 justify-content-between align-items-start">
                    <div>
                        <h6 class="mb-1">
                            <a asp-controller="Events" asp-action="Details" asp-route-id="@r.EventID">@r.Event?.Title</a>
                        </h6>
                        <p class="mb-1 text-warning">@(new string('★', r.Rating))@(new string('☆', 5 - r.Rating))</p>
                        @if (!string.IsNullOrEmpty(r.Comment))
                        {
                            <p class="mb-0 small">@r.Comment</p>
                        }
                    </div>
                    <small class="text-muted">@r.ReviewDate.ToString("MMM dd, yyyy")</small>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">
        You haven't submitted any reviews yet. After attending an event, you can leave a review from the event page.
    </div>
    <a asp-controller="Events" asp-action="Index" class="btn btn-primary">Browse Events</a>
}
