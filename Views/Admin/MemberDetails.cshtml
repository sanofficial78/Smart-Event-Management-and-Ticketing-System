@model EventManagementSystem.Models.Member
@{
    ViewData["Title"] = Model.FirstName + " " + Model.LastName;
    Layout = "_AdminLayout";
}
<div class="table-admin p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0"><i class="bi bi-person me-2"></i>@Model.FirstName @Model.LastName</h5>
        <a asp-action="Members" class="btn btn-outline-secondary btn-sm">← Back</a>
    </div>
    <div class="row g-3">
        <div class="col-md-6">
            <label class="text-muted small">Email</label>
            <div>@Model.Email</div>
        </div>
        <div class="col-md-6">
            <label class="text-muted small">Phone</label>
            <div>@(Model.Phone ?? "—")</div>
        </div>
        <div class="col-12">
            <label class="text-muted small">Address</label>
            <div>@(Model.Address ?? "—")</div>
        </div>
        <div class="col-12">
            <label class="text-muted small">Joined</label>
            <div>@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
        </div>
        <div class="col-12">
            <span>Status: </span>
            @if (Model.IsActive)
            { <span class="admin-badge bg-success">Active</span> }
            else
            { <span class="admin-badge bg-secondary">Inactive</span> }
        </div>
        <div class="col-12">
            <h6 class="mt-3">Bookings (@(Model.Bookings?.Count ?? 0))</h6>
            @if (Model.Bookings?.Any() == true)
            {
                <ul class="list-group list-group-flush">
                    @foreach (var b in Model.Bookings.Take(10))
                    {
                        <li class="list-group-item px-0 d-flex justify-content-between">
                            <span>@b.Event?.Title</span>
                            <span class="admin-badge bg-@(b.Status == "Confirmed" ? "primary" : b.Status == "Completed" ? "success" : "secondary")">@b.Status</span>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted small">No bookings</p>
            }
        </div>
        <div class="col-12">
            <form asp-action="ToggleMemberStatus" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.MemberID" />
                <button type="submit" class="btn btn-@(Model.IsActive ? "warning" : "success") btn-sm">
                    @(Model.IsActive ? "Deactivate Member" : "Activate Member")
                </button>
            </form>
            <form asp-action="DeleteMember" method="post" class="d-inline" onsubmit="return confirm('Delete this member? Cannot undo. Members with bookings or reviews cannot be deleted.');">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.MemberID" />
                <button type="submit" class="btn btn-danger btn-sm">Delete Member</button>
            </form>
        </div>
    </div>
</div>
